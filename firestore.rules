rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    function isValidMenuItem(data) {
      return data.keys().hasAll(['category', 'name', 'description', 'img', 'createdAt', 'updatedAt']) 
        && data.keys().size() == 6
        && data.category is string && data.category.size() > 0 && data.category.size() <= 100
        && data.name is string && data.name.size() > 0 && data.name.size() <= 100
        && data.description is string && data.description.size() <= 500
        && data.img is string && data.img.size() <= 1000
        && data.createdAt is number
        && data.updatedAt is number;
    }

    function isValidReview(data) {
      return data.keys().hasAll(['author', 'rating', 'comment', 'createdAt'])
        && data.keys().size() == 4
        && data.author is string && data.author.size() > 0 && data.author.size() <= 100
        && data.rating is number && data.rating >= 1 && data.rating <= 5
        && data.comment is string && data.comment.size() > 0 && data.comment.size() <= 1000
        && data.createdAt is number;
    }

    match /admins/{userId} {
      allow read: if true;
      allow create: if request.auth.uid == userId && request.auth.token.email == "inoaj2104@gmail.com";
      allow write: if false;
    }

    match /menu/{menuId} {
      allow read: if true;
      allow write: if true; // Temporarily open for custom local credentials mockup

      match /reviews/{reviewId} {
        allow read: if true;
        allow list: if true;
        allow create: if true; // Temporarily open for custom local credentials mockup
      }
    }
  }
}
